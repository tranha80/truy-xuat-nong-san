# Cổng chạy server
PORT=3000

# Môi trường: development | production
NODE_ENV=development

# Bí mật session (ĐỔI SANG chuỗi ngẫu nhiên dài khi deploy thật)
SESSION_SECRET=doi-thanh-chuoi-bi-mat-dai-ngau-nhien-o-day

# Tên file cơ sở dữ liệu SQLite (nằm trong thư mục /data)
DB_FILE=nongsan.db

# URL gốc của site (dùng để sinh QR code)
# Ví dụ deploy: https://truyxuat.example.com
BASE_URL=http://localhost:3000

# Giới hạn upload ảnh (MB)
UPLOAD_LIMIT_MB=5
