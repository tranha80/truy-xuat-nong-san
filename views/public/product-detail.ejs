<div class="row justify-content-center">
  <div class="col-md-10">
    <div class="card mb-4">
      <div class="row g-0">
        <div class="col-md-4 text-center p-3">
          <% if (product.image) { %>
            <img src="<%= product.image %>" class="product-thumb" alt="<%= product.name %>" />
          <% } else { %>
            <div class="product-thumb d-flex align-items-center justify-content-center text-muted">
              <i class="bi bi-image" style="font-size:2rem"></i>
            </div>
          <% } %>
        </div>
        <div class="col-md-8">
          <div class="card-body">
            <h3 class="card-title"><%= product.name %></h3>
            <p class="text-muted mb-2">
              <i class="bi bi-tag"></i> Mã lô: <strong><%= product.batch_code %></strong>
              <% if (product.variety) { %> · Giống: <%= product.variety %><% } %>
            </p>
            <p class="mb-1"><i class="bi bi-calendar3"></i> Ngày thu hoạch: <%= product.harvest_date || '—' %></p>
            <p class="mb-1"><i class="bi bi-people"></i> Nông dân: <%= product.farmer_name %> · ☎ <%= product.farmer_phone || '—' %></p>
            <p class="mb-1"><i class="bi bi-geo-alt"></i> <%= product.farm_address %>, <%= product.district %>, <%= product.province %></p>
            <p class="mb-1"><i class="bi bi-box"></i> Sản lượng: <%= product.quantity %> <%= product.unit %></p>
            <% if (product.certifications) { %>
              <p class="mb-1">
                <% product.certifications.split(',').forEach(function(c){ %>
                  <span class="badge badge-cert"><%= c.trim() %></span>
                <% }) %>
              </p>
            <% } %>
            <% if (product.description) { %>
              <p class="mt-2"><%= product.description %></p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-4">
      <div class="col-md-7">
        <h4><i class="bi bi-list-check"></i> Hành trình sản phẩm</h4>
        <% if (product.stages && product.stages.length) { %>
          <div class="timeline">
            <% product.stages.forEach(function(s){ %>
              <div class="timeline-item">
                <h6><%= s.stage_name %></h6>
                <div class="date"><%= s.performed_at || '' %> · <%= s.location || '' %></div>
                <p class="mb-0"><%= s.description || '' %></p>
                <% if (s.image) { %>
                  <img src="<%= s.image %>" class="mt-2" style="max-width:160px;border-radius:0.5rem" />
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p class="text-muted">Chưa có công đoạn nào được ghi nhận.</p>
        <% } %>
      </div>

      <div class="col-md-5 text-center">
        <h4><i class="bi bi-qr-code"></i> Mã QR sản phẩm</h4>
        <div class="qr-box">
          <img src="<%= qrDataUrl %>" alt="QR code" width="240" height="240" />
        </div>
        <p class="mt-2 text-muted small"><%= traceUrl %></p>
        <a class="btn btn-outline-primary btn-sm" href="<%= qrDataUrl %>" download="qr-<%= product.batch_code %>.png">
          <i class="bi bi-download"></i> Tải QR
        </a>
      </div>
    </div>
  </div>
</div>
